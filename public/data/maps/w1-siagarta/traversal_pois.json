        "raw": {
            "$cdbtype": "element",
            "id": "Z1_World_Greenlands_Obelisk_1",
            "texts": {},
            "props": {
                "targetZone": "Z1_Meridion",
                "cutscene": "Cutscenes/Z1_Meridion.mogcutscene"
            },
            "script": "",
            "dialog": [
                {
                    "id": "StartCutscene",
                    "text": "Off these coasts, in the darkness of the Lost Gods Age, a Sunling pirate known as Meridion retrieved a forgotten Gate from the seabed and placed it on the sandy shore.",
                    "choices": [],
                    "props": {
                        "skipDelay": 8
                    }
                },
                {
                    "id": "Cutscene2",
                    "text": "When the Sunlings’ arrogance and greed turned the worlds against them, they were saved by Meridion’s Gate. They crossed it, sealed it and went into exile.",
                    "choices": [],
                    "props": {
                        "skipDelay": 8
                    }
                },
                {
                    "id": "Cutscene3",
                    "text": "Many generations passed before the Gate was reopened. But today, as the Sunlings come back, the shores of Meridion are the doorway to their old world: Siagarta.",
                    "choices": [],
                    "props": {
                        "skipDelay": 8
                    }
                }
            ],
            "chunkId": "L4_+0_+2",
            "worldX": -822.3127,
            "worldY": 1973.0588
        }
