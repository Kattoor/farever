---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/urls';
const defaultRoot = url('model-library');
const viewerScript = url('model-viewer/viewer-tree-multiprefab.js');
---
<BaseLayout title="Models" wide={true}>
  <section class="models-page">
    <div id="app" class="viewer-shell" data-default-root={defaultRoot}>
      <aside class="viewer-sidebar">
        <div class="card viewer-sidebar-card viewer-browser-card">
          <div class="viewer-browser-header">
            <div class="viewer-section-title">Model browser</div>
            <label class="viewer-field">
              <span class="viewer-label">Model library root</span>
              <div class="viewer-row">
                <input id="export-root" type="text" value={defaultRoot} spellcheck="false" />
                <button id="refresh-models" type="button" class="viewer-button">Reload</button>
              </div>
            </label>
            <label class="viewer-field">
              <span class="viewer-label">Search models</span>
              <input id="model-search" type="text" placeholder="Type part of a folder or model name…" spellcheck="false" />
            </label>
            <div id="catalog-status" class="viewer-status muted">Loading model library…</div>
          </div>
          <div id="model-list" class="viewer-model-list"></div>
        </div>
      </aside>

      <div class="viewer-stage card">
        <div id="viewport" class="viewer-viewport"></div>
        <div class="viewer-stage-controls">
          <label class="viewer-toggle viewer-stage-toggle">
            <input id="auto-rotate" type="checkbox" />
            <span>Auto rotate</span>
          </label>
          <label id="part-switcher-wrap" class="viewer-field viewer-part-switcher" hidden>
            <span class="viewer-label">Prefab part</span>
            <select id="part-select" class="viewer-select">
              <option value="__combined__">Combined</option>
            </select>
          </label>
        </div>
      </div>
    </div>
  </section>

  <script type="importmap">{"imports":{"three":"https://unpkg.com/three@0.160.0/build/three.module.js"}}</script>
  <script type="module" src={viewerScript}></script>
</BaseLayout>

<style is:global>
  .models-page {
    height: calc(100svh - 14rem);
    min-height: 0;
    overflow: hidden;
  }
  .viewer-shell {
    display: grid;
    grid-template-columns: minmax(300px, 360px) minmax(0, 1fr);
    gap: 1rem;
    height: 100%;
    min-height: 0;
    align-items: stretch;
    overflow: hidden;
  }
  .viewer-sidebar {
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    overflow: hidden;
    justify-content: flex-start;
    align-self: stretch;
  }
  .viewer-sidebar-card {
    display: grid;
    gap: 0.85rem;
  }
  .viewer-browser-card {
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    height: 100%;
  }
  .viewer-browser-header {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 0.35rem;
    padding: 0.9rem 0.9rem 0 0.9rem;
    flex: 0 0 auto;
    align-content: start;
  }
  .viewer-section-title {
    font-size: 1rem;
    font-weight: 700;
  }
  .viewer-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 650;
    opacity: 0.85;
    margin-bottom: 0.35rem;
  }
  .viewer-field {
    display: block;
  }
  .viewer-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
  }
  .viewer-button {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.6rem 0.85rem;
    background: rgba(255,255,255,0.05);
    color: inherit;
    cursor: pointer;
  }
  .viewer-button:hover { background: rgba(255,255,255,0.08); }
  .viewer-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
  }
  .viewer-stage {
    position: relative;
  }
  .viewer-stage-controls {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 6;
    display: grid;
    gap: 0.7rem;
    min-width: 220px;
    max-width: min(320px, calc(100% - 24px));
    padding: 0.85rem;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.28);
  }
  .viewer-stage-toggle {
    justify-self: start;
  }
  .viewer-part-switcher {
    display: grid;
    gap: 0.35rem;
  }
  .viewer-select {
    width: 100%;
    box-sizing: border-box;
    padding: 0.65rem 0.8rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.18);
    color: inherit;
  }
  .viewer-status {
    font-size: 0.9rem;
    white-space: pre-wrap;
  }
  .viewer-status.error { color: #ffb3b3; }
  .viewer-model-list {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    display: block;
    padding: 0 0.1rem 0.9rem 0.75rem;
    margin: 0;
    align-content: start;
    justify-content: flex-start;
    scrollbar-gutter: stable;
    overscroll-behavior: contain;
    scrollbar-width: auto;
  }
  .viewer-model-list > * {
    width: 100%;
  }
  .viewer-model-list::-webkit-scrollbar {
    width: 12px;
  }
  .viewer-model-list::-webkit-scrollbar-track {
    background: rgba(255,255,255,0.04);
    border-radius: 999px;
  }
  .viewer-model-list::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.22);
    border-radius: 999px;
    border: 2px solid rgba(0,0,0,0);
    background-clip: padding-box;
  }
  .tree-folder {
    margin: 0;
    display: block;
  }
  .tree-folder > summary {
    list-style: none;
    display: block;
  }
  .tree-folder > summary::-webkit-details-marker { display: none; }
  .tree-folder-line {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
  }
  .tree-folder-summary {
    cursor: pointer;
    user-select: none;
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 0.38rem 0.5rem;
    border-radius: 10px;
    transition: background-color 120ms ease;
  }
  .tree-folder-summary:hover { background: rgba(255,255,255,0.05); }
  .tree-folder-main {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }
  .tree-folder-caret {
    width: 0.9rem;
    color: rgba(255,255,255,0.72);
    transition: transform 120ms ease;
    flex: 0 0 auto;
  }
  .tree-folder[open] .tree-folder-caret { transform: rotate(90deg); }
  .tree-folder-name {
    font-weight: 600;
    overflow-wrap: anywhere;
  }
  .tree-folder-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    height: 1.75rem;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.72);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    padding: 0 0.45rem;
    margin-left: 0.6rem;
    flex: 0 0 auto;
    background: rgba(255,255,255,0.03);
  }
  .tree-branch {
    display: block;
    margin: 0.08rem 0 0.14rem 0.55rem;
    padding-left: 0.55rem;
    border-left: 1px solid rgba(255,255,255,0.08);
  }
  .model-item {
    width: 100%;
    box-sizing: border-box;
    text-align: left;
    border: 1px solid transparent;
    background: transparent;
    color: inherit;
    border-radius: 10px;
    padding: 0.38rem 0.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.42rem;
  }
  .model-item::before {
    content: '◦';
    opacity: 0.55;
    flex: 0 0 auto;
  }
  .model-item:hover { background: rgba(255,255,255,0.05); }
  .model-item.active {
    border-color: rgba(117,167,255,0.45);
    background: rgba(80,120,255,0.16);
  }
  .model-item-label { overflow-wrap: anywhere; }
  .model-empty { opacity: 0.75; padding: 0.35rem 0; }
  .viewer-stage {
    min-width: 0;
    min-height: 0;
    padding: 0;
    overflow: hidden;
    height: 100%;
  }
  .viewer-viewport {
    width: 100%;
    height: 100%;
    min-height: 0;
  }
  input[type="text"] {
    width: 100%;
    box-sizing: border-box;
    padding: 0.65rem 0.8rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.12);
    color: inherit;
  }
  @media (max-width: 980px) {
    .viewer-shell { grid-template-columns: 1fr; height: auto; min-height: 0; }
    .viewer-stage, .viewer-viewport { min-height: 60vh; }
    .viewer-sidebar { height: auto; }
    .viewer-browser-card { min-height: 420px; }
  }
</style>
